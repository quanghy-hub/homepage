{
  "manifest_version": 3,
  "name": "Homepage",
  "version": "1.0.0",
  "description": "Custom new tab page with grouped quicklinks",
  "incognito": "split",
  "chrome_url_overrides": {
    "newtab": "src/newtab/index.html"
  },
  "permissions": [
    "storage",
    "contextMenus",
    "activeTab"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "css": [
        "src/content/cookie-bypass/styles.css"
      ],
      "js": [
        "src/content/cookie-bypass/index.js"
      ],
      "run_at": "document_end"
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "css": [
        "src/content/video-floating/styles.css"
      ],
      "js": [
        "src/content/video-floating/index.js"
      ],
      "run_at": "document_end",
      "all_frames": true
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/video-floating/page-api.js"
      ],
      "run_at": "document_end",
      "all_frames": true,
      "world": "MAIN"
    }
  ],
  "background": {
    "service_worker": "src/background/index.js"
  },
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  }
}