{
  "manifest_version": 3,
  "name": "Homepage",
  "version": "1.0.0",
  "description": "Custom new tab page with grouped quicklinks",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": [
    "storage",
    "contextMenus"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "128": "icon128.png"
  }
}